# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=loyalty_db
DB_USER=loyalty_user
DB_PASSWORD=loyalty_pass

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka Configuration
KAFKA_BROKERS=kafka:29092

# JWT Security (Keycloak)
JWT_ISSUER_URI=http://localhost:8080/realms/loyalty
JWT_JWK_SET_URI=http://localhost:8080/realms/loyalty/protocol/openid-connect/certs

# Application Server
SERVER_PORT=8081

# API Bonification externe (équipe 5GI — bonusapi.onrender.com)
BONIFICATION_ENABLED=true
BONIFICATION_API_BASE_URL=https://bonusapi.onrender.com
BONIFICATION_LOGIN=
BONIFICATION_PASSWORD=

# Kernel Core Configuration
KERNEL_CORE_URL=http://kernel-core:8090
KERNEL_SERVICE_CLIENT_ID=loyalty-service
KERNEL_SERVICE_CLIENT_SECRET=changeme
KERNEL_TOKEN_ENDPOINT=http://localhost:8080/realms/loyalty/protocol/openid-connect/token
