# Database Configuration
# Le backend tourne sur l'hôte (./mvnw spring-boot:run) et se connecte aux conteneurs
# docker-compose via localhost. Si 5432/6379 sont déjà pris sur ta machine, définis
# DB_HOST_PORT/REDIS_HOST_PORT (ports hôte utilisés par docker-compose) et aligne
# DB_PORT/REDIS_PORT dessus.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=loyalty_db
DB_USER=loyalty_user
DB_PASSWORD=loyalty_pass
# DB_HOST_PORT=5433

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_HOST_PORT=6380

# Kafka Configuration
KAFKA_BROKERS=localhost:9092

# JWT Security — validation des jetons émis par Kernel Core.
# Les défauts d'application.yml pointent déjà sur le bon issuer ("kernel-core") et le
# JWKS https://kernel-core.yowyob.com/.well-known/jwks.json ; ne définir JWT_ISSUER_URI/
# JWT_JWK_SET_URI que pour cibler une autre instance Kernel Core.

# Application Server
SERVER_PORT=8081


# Kernel Core Configuration — ClientApplication dédié "loyality-program"
# (X-Client-Id/X-Api-Key envoyés par le backend ; la vraie clé API va dans .env, jamais ici)
KERNEL_CORE_URL=https://kernel-core.yowyob.com
KERNEL_SERVICE_CLIENT_ID=loyality-program
KERNEL_SERVICE_CLIENT_SECRET=changeme
# Laisser vide : Kernel Core ne supporte pas client_credentials (KernelCoreTokenService
# reste inactif tant que cette variable est vide — comportement voulu).
KERNEL_TOKEN_ENDPOINT=
# Tenant plateforme KernelCore sous lequel /api/v1/auth/login se connecte (X-Tenant-Id)
KERNEL_TENANT_ID=11111111-1111-1111-1111-111111111111
